<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#111827"
    android:padding="16dp">

    <!-- EPC 显示 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0F1628"
        android:padding="10dp"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RFID EPC"
            android:textSize="9sp"
            android:textColor="#475569"
            android:layout_marginBottom="2dp"/>
        <TextView
            android:id="@+id/tvDetailEpc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="-"
            android:textSize="13sp"
            android:textColor="#38BDF8"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- 标签名称 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="标签名称"
        android:textSize="11sp"
        android:textColor="#64748B"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etDetailName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="请输入货品名称"
        android:textColor="#E2E8F0"
        android:textColorHint="#475569"
        android:background="#1E293B"
        android:padding="10dp"
        android:textSize="13sp"
        android:layout_marginBottom="10dp"/>

    <!-- 类别 + 数量 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="类别"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginBottom="4dp"/>
            <Spinner
                android:id="@+id/spinnerDetailCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#1E293B"
                android:padding="8dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数量"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etDetailQty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="1"
                android:inputType="number"
                android:textColor="#E2E8F0"
                android:textColorHint="#475569"
                android:background="#1E293B"
                android:padding="10dp"
                android:textSize="13sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- 存放位置 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="存放位置"
        android:textSize="11sp"
        android:textColor="#64748B"
        android:layout_marginBottom="4dp"/>
    <EditText
        android:id="@+id/etDetailLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="如：A-03-02"
        android:textColor="#E2E8F0"
        android:textColorHint="#475569"
        android:background="#1E293B"
        android:padding="10dp"
        android:textSize="13sp"
        android:layout_marginBottom="10dp"/>

    <!-- 使用部门 + 使用人 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="10dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="使用部门"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etDetailDepartment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="如：研发部"
                android:textColor="#E2E8F0"
                android:textColorHint="#475569"
                android:background="#1E293B"
                android:padding="10dp"
                android:textSize="13sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="使用人"
                android:textSize="11sp"
                android:textColor="#64748B"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etDetailUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="如：张三"
                android:textColor="#E2E8F0"
                android:textColorHint="#475569"
                android:background="#1E293B"
                android:padding="10dp"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- 入库/采购时间 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="10dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="入库/采购时间"
                android:textSize="10sp"
                android:textColor="#475569"
                android:layout_marginBottom="4dp"/>
            <EditText
                android:id="@+id/etDetailPurchaseDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="如：2026-04-09"
                android:textColor="#E2E8F0"
                android:textColorHint="#475569"
                android:background="#1E293B"
                android:padding="10dp"
                android:textSize="13sp"
                android:inputType="date"/>
        </LinearLayout>

    </LinearLayout>

    <!-- 只读信息 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#0F1628"
        android:padding="8dp">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="信号强度"
                android:textSize="9sp"
                android:textColor="#475569"/>
            <TextView
                android:id="@+id/tvDetailRssi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:fontFamily="monospace"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="扫描时间"
                android:textSize="9sp"
                android:textColor="#475569"/>
            <TextView
                android:id="@+id/tvDetailTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:fontFamily="monospace"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
